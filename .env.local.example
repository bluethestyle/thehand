# Supabase — 기존 프로젝트의 값을 넣으세요.
# (Supabase 대시보드 → Project Settings → API)

# 손님 태블릿(브라우저)에서 읽기용. 공개되어도 되는 anon 키.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 관리자 쓰기 전용. 절대 클라이언트로 노출 금지(서버 라우트에서만 사용). 커밋 금지.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# (권장) 관리자 세션 쿠키 서명용 임의 비밀(32바이트 랜덤 등).
# 미설정 시 service_role 키로 폴백하지만, 키 분리를 위해 별도 지정 권장.
ADMIN_SESSION_SECRET=

# 비워두면 앱은 내장 시드 데이터로 읽기 전용 미리보기 모드로 동작합니다.
